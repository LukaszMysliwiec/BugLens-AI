# OpenAI API key – required for AI-powered analysis
OPENAI_API_KEY=sk-...

# OpenAI model to use (defaults to gpt-4o-mini for cost efficiency)
OPENAI_MODEL=gpt-4o-mini

# Maximum tokens to use per AI request
OPENAI_MAX_TOKENS=800

# HTTP request timeout in seconds
HTTP_TIMEOUT=15

# Maximum number of links to check during broken-link detection
MAX_LINKS_TO_CHECK=20
